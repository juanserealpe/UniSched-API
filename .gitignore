# =========================
# Environment / secrets
# =========================
.env

# Ignore environment-specific configs
application-*.yml
application-*.properties

# Allow base configs (IMPORTANT)
!application.yml
!application.properties

# =========================
# Maven Wrapper
# =========================
# Keep wrapper config
!.mvn/wrapper/maven-wrapper.properties

# Ignore wrapper binaries (optional but recommended)
.mvn/wrapper/maven-wrapper.jar

